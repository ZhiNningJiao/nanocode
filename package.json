{
  "name": "nanocode",
  "version": "0.1.0",
  "type": "module",
  "description": "Minimal terminal workspace for managing projects and AI coding assistants",
  "scripts": {
    "dev": "node --watch server/index.js",
    "start": "node server/index.js",
    "pm2:start": "PM2_HOME=.pm2 PORT=3001 pm2 start server/index.js --name nanocode",
    "pm2:stop": "PM2_HOME=.pm2 pm2 stop nanocode",
    "pm2:logs": "PM2_HOME=.pm2 pm2 logs nanocode",
    "test": "node --test server/tests/*.test.js"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "express": "^4.21.0",
    "node-pty": "^1.1.0-beta34",
    "ws": "^8.18.0"
  }
}
